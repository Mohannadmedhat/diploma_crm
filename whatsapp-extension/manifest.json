{
  "manifest_version": 3,
  "name": "مساعد أتمتة واتساب الأكاديمية",
  "version": "2.0",
  "description": "إضافة كروم مخصصة لأتمتة إرسال رسائل الواتساب وإغلاق التبويبات تلقائياً.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://diploma-crm.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://diploma-crm.vercel.app/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
